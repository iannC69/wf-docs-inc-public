# Assets with content-hash in filename — safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static media — long cache, revalidate
/wallpaper/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/icons/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/videos/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# HTML pages — must revalidate so users get fresh content
/*
  Cache-Control: public, max-age=0, must-revalidate
